TELEGRAM_TOKEN=123456789:replace_with_bot_token
ALLOWED_USERS=123456789
ADMIN_USERS=123456789
OPERATOR_USERS=

DB_PASS=replace_with_a_long_random_password
DATABASE_URL=postgresql://aggasys:replace_with_a_long_random_password@postgres:5432/aggasys

# Use deepseek for Sean's Ubuntu VM pilot. Use ollama only when running local models.
MODEL_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace_with_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Set EMBEDDING_PROVIDER=ollama to enable vector search with local Ollama embeddings.
# Set EMBEDDING_PROVIDER=disabled for the API-only pilot; Gray will fall back to text search.
EMBEDDING_PROVIDER=disabled
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b
EMBED_MODEL=nomic-embed-text
OLLAMA_KEEP_ALIVE=24h
OLLAMA_NUM_CTX=4096

HERMES_TIMEZONE=Asia/Singapore
HERMES_SCHEDULER_INTERVAL_SECONDS=30
HERMES_SCHEDULER_BATCH_SIZE=5
HERMES_JOB_FAILURE_LIMIT=3
HERMES_BACKUP_RETENTION_DAYS=30
HERMES_AUDIT_RETENTION_DAYS=180
HERMES_OPERATION_RETENTION_DAYS=365
HERMES_GROUP_CHAT_MODE=mention
GRAY_BOT_USERNAME=GrayBot

HISTORY_LIMIT=6
SUMMARY_TRIGGER=20
MEMORY_QUEUE_SIZE=100
MEMORY_WORKERS=1
RATE_LIMIT_MESSAGES=30
RATE_LIMIT_WINDOW_SECONDS=60
MAX_DOCUMENT_BYTES=5242880
MAX_VOICE_BYTES=10485760
MAX_PHOTO_BYTES=5242880

WHISPER_MODEL=tiny
# VISION_MODEL=llava
